#!/usr/bin/env bash
# =============================================================
#  Git pre-commit hook — barra segredos antes de virarem commit
#  Instale com: ./scripts/install-hooks.sh
# =============================================================
set -euo pipefail

fail() { printf '\033[1;31m✖ COMMIT BLOQUEADO:\033[0m %s\n' "$*" >&2; exit 1; }

staged=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Nunca deixar um .env real ser commitado ------------------
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  case "$f" in
    .env.example) : ;;                       # esse é público, ok
    .env|.env.*|*.env) fail "arquivo de ambiente staged: $f" ;;
  esac
done <<< "$staged"

# 2. Varredura de padrões de chave no conteúdo staged ---------
#    (chaves reais têm prefixos característicos)
patterns='sk-or-v1-[A-Za-z0-9]{16}|ghp_[A-Za-z0-9]{20}|sk-[A-Za-z0-9]{24}|sbp_[A-Za-z0-9]{20}|vcp_[A-Za-z0-9]{20}|m0-[A-Za-z0-9]{20}|[0-9]{8,}:AA[A-Za-z0-9_-]{30}'

if git diff --cached -U0 | grep -nE "^\+" | grep -Eqi "$patterns"; then
  git diff --cached -U0 | grep -nE "^\+" | grep -Ein "$patterns" || true
  fail "conteúdo com cara de chave/segredo detectado (veja acima)."
fi

exit 0
